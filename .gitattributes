# Auto-detect text files and normalize line endings
* text=auto

# Python files
*.py text eol=lf

# Documentation
*.md text eol=lf
*.rst text eol=lf

# Config
*.yaml text eol=lf
*.yml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.gz binary
*.zip binary
*.db binary
